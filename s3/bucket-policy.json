{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Action": [
                "s3:GetReplicationConfiguration",
                "s3:ListBucket"
            ],
            "Effect": "Allow",
            "Resource": [
                "arn:aws:s3:::velero-backup-primary"
            ],
            "Principal": {
                "AWS": "arn:aws:iam::[ACCOUNT_ID]:role/VeleroBucketReplicationRole"
            }
        },
        {
            "Action": [
                "s3:GetObjectVersionForReplication",
                "s3:GetObjectVersionAcl",
                "s3:GetObjectVersionTagging"
            ],
            "Effect": "Allow",
            "Resource": [
                "arn:aws:s3:::velero-backup-primary/*"
            ],
            "Principal": {
                "AWS": "arn:aws:iam::[ACCOUNT_ID]:role/VeleroBucketReplicationRole"
            }
        },
        {
            "Action": [
                "s3:ReplicateObject",
                "s3:ReplicateDelete",
                "s3:ReplicateTags"
            ],
            "Effect": "Allow",
            "Resource": "arn:aws:s3:::velero-backup-replica/*",
            "Principal": {
                "AWS": "arn:aws:iam::[ACCOUNT_ID]:role/VeleroBucketReplicationRole"
            }
        }
    ]
}